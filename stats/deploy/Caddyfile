bitsocial.net {
	encode gzip

	@stats5chan path /stats/5chan
	redir @stats5chan /stats/d/bitsocial-5chan/5chan-stats?orgId=1 302

	@statsNoSlash path /stats
	redir @statsNoSlash /stats/ 308

	handle /stats/* {
		reverse_proxy 127.0.0.1:3300
	}

	@docsNoSlash path /docs
	redir @docsNoSlash /docs/ 308

	handle_path /docs/* {
		root * /srv/bitsocial-web/current/dist/docs
		try_files {path} {path}/ {path}.html /index.html
		file_server
	}

	root * /srv/bitsocial-web/current/dist/about
	try_files {path} {path}/ /index.html
	file_server
}

newsletter.bitsocial.net {
	reverse_proxy 127.0.0.1:9000

	header {
		Access-Control-Allow-Origin https://bitsocial.net
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization"
		Access-Control-Max-Age 86400
	}

	@options method OPTIONS
	respond @options 204

	encode gzip
}
